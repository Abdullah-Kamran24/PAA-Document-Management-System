@model DMS.Models.MainOffice

@{
    ViewBag.Title = "Update Main Office";
    var locationList = ViewBag.LocationList as List<DMS.Models.Location>;
}

<title>Update Main Office</title>

<div class="row">
    <div class="col-12 text-center">
        <h1>Update Record of Main Office</h1>
    </div>
</div>

<div class="row">
    <div class="col-3"></div>
    <div class="col-6">
        <form>

            <input type="hidden" id="txtMoID" value="@Model.MoID" />

            <div class="input-group mb-3">
                <span class="input-group-text">Location</span>
                <select class="form-select" id="ddlLocation">
                    <option value="">-- Select Location --</option>
                    @foreach (var loc in locationList)
                    {
                        <option value="@loc.LoID" @(Model.LoId == loc.LoID ? "selected" : "")>
                            @loc.ShortName (@loc.LoCode)
                        </option>
                    }
                </select>
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text">Short Name</span>
                <input type="text" class="form-control" id="txtSname" value="@Model.ShortName" />
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text">Full Name</span>
                <input type="text" class="form-control" id="txtFname" value="@Model.FullName" />
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text">Code</span>
                <input type="text" class="form-control" id="txtCode" value="@Model.MoCode" />
            </div>

            <input type="button" value="Update" class="btn btn-primary" id="btnUpdate" />
        </form>

        <br />
        <a href="/mo/index">Back to List</a>
    </div>
    <div class="col-3"></div>
</div>

@section PageScripts {
    <script src="~/js/MO/update.js"></script>
}
