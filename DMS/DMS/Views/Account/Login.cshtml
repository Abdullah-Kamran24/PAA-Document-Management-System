@{
    ViewBag.Title = "Login - DMS";
}

<!DOCTYPE html>
<html>
<head>
    <title>Login - DMS Project</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        body {
            background: linear-gradient(to right, #f5f7fa, #c3cfe2);
            height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-box {
            max-width: 420px;
            margin: 60px auto;
            padding: 30px 35px;
            background-color: #fff;
            border-radius: 15px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        .login-title {
            color: #003366;
            font-weight: bold;
            margin-bottom: 25px;
        }

        .form-control {
            padding-left: 40px;
        }

        .input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #aaa;
        }

        .form-group {
            position: relative;
        }

        .btn-login {
            background-color: #003366;
            color: #fff;
            font-weight: 600;
        }

            .btn-login:hover {
                background-color: #00509e;
            }

        .logo {
            max-width: 200px;
            margin-bottom: 20px;
        }

        .footer-text {
            font-size: 0.9rem;
            color: #555;
        }
    </style>
</head>
<body>

    <div class="container text-center">
        <img src="~/img/logo PAA.png" alt="DMS Logo" class="logo" />
        <h2 class="fw-bold">DMS Project - Document Management System</h2>
        <h6 class="mb-4 footer-text">by Abdullah Kamran | Coordinator: Abdul Majid</h6>

        <div class="login-box">
            <h4 class="login-title">Login</h4>

            <form method="post" asp-controller="Account" asp-action="Login">
                <div class="form-group mb-3">
                    <span class="input-icon"><i class="fa fa-user"></i></span>
                    <input type="text" name="username" class="form-control" placeholder="Username" required />
                </div>

                <div class="form-group mb-4">
                    <span class="input-icon"><i class="fa fa-lock"></i></span>
                    <input type="password" name="password" class="form-control" placeholder="Password" required />
                </div>

                <button type="submit" class="btn btn-login w-100">Sign In</button>
            </form>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-danger mt-3">@ViewBag.Message</div>
            }
        </div>
    </div>

</body>
</html>
