@model DMS.Models.Location
@{
    ViewBag.Title = "Update Location";
}
`
<title>Update Location</title>

<div class="row">
    <div class="col-12 text-center">
        <h1>Update Record of Location</h1>
    </div>
</div>

<div class="row">
    <div class="col-3"></div>
    <div class="col-6">
        <form >

            <input type="hidden" id="txtLID" value="@Model.LoID" />

            <div class="input-group mb-3">
                <span class="input-group-text">Short Name</span>
                <input type="text" class="form-control" id="txtSname" value="@Model.ShortName" />
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text">Full Name</span>
                <input type="text" class="form-control" id="txtFname" value="@Model.FullName" />
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text">Code</span>
                <input type="text" class="form-control" id="txtCode" value="@Model.LoCode" />
            </div>

            <input type="button" value="Update" class="btn btn-primary" id="btnUpdate" />
        </form>

        <br />
        <a href="/location/index">Back to List</a>
    </div>
    <div class="col-3"></div>
</div>


@section PageScripts {
    <script src="/js/location/update.js"></script>
}