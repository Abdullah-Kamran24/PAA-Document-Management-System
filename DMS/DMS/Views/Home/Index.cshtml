<!DOCTYPE html>
<html lang="en">
<head>
    <title>DMS Project - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(to right, #dfe9f3, #ffffff);
            font-family: 'Segoe UI', sans-serif;
        }

        .logo-img {
            max-width: 180px;
            margin: 20px auto;
            display: block;
        }

        .main-heading {
            color: #0a3d62;
            text-align: center;
            font-weight: 700;
        }

        .sub-heading {
            color: #1e272e;
            text-align: center;
            font-size: 1.5rem;
            margin-bottom: 10px;
        }

        .footer-text {
            text-align: center;
            color: #636e72;
            font-size: 14px;
            margin-top: 40px;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>

    <!-- Logo -->
    <img src="~/img/logo PAA.png" alt="logoPAA" class="logo-img" >

    <!-- Titles -->
    <h1 class="main-heading">DMS PROJECT</h1>
    <h4 class="sub-heading">Document Management System</h4>

    <!-- Info Card -->
    <div class="container mt-5">
        <div class="card p-4 bg-light">
            <h5 class="text-primary">Submitted By:</h5>
            <p class="ms-3">Abdullah Kamran</p>

            <h5 class="text-primary mt-3">Coordinator:</h5>
            <p class="ms-3">Abdul Majid</p>

            <h5 class="text-primary mt-3">Institute:</h5>
            <p class="ms-3">Pakistan Airports Authority (PAA)</p>
        </div>
    </div>

    <!-- Footer -->
    <p class="footer-text">&copy; 2025 DMS Project. All rights reserved.</p>

</body>
</html>
